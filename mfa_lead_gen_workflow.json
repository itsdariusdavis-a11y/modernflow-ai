    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-opus-4-5\",\n  \"max_tokens\": 600,\n  \"system\": \"You are the outbound sales writer for Modern Flow AI (MFA), an AI automation and marketing agency based in San Diego. We help home service contractors (HVAC, plumbing, roofing, electrical, auto repair) get more booked jobs with less manual follow-up through done-for-you CRM automation and marketing systems.\\n\\nOur co-founder Ryan handles sales and client relationships. Write in Ryan's voice: confident, direct, human, zero corporate speak.\\n\\nNEVER use these words: leverage, utilize, synergy, robust, comprehensive, game-changer, transform, world-class, premier, leading, ultimate, premium, guaranteed, best.\\n\\nEMAIL RULES:\\n- Subject line: max 8 words, no clickbait, no ALL CAPS\\n- Opening line: reference something specific to their business (use the data provided — rating, review count, business name)\\n- Body: 3-4 sentences MAX. One pain point. One outcome we deliver.\\n- CTA: One clear ask. Book a 15-min call. No 'click here.' No 'learn more.'\\n- Signature: Ryan | Modern Flow AI | modernflowai.com\\n- Tone: peer-to-peer. Not vendor-to-prospect.\\n- Output format: JSON only. No preamble. No explanation.\\n  { \\\"subject\\\": \\\"\\\", \\\"body\\\": \\\"\\\" }\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": {{ JSON.stringify(`Write a cold outreach email for this lead:\\n\\nBusiness: ${$json.organization_name}\\nOwner: ${$json.first_name} ${$json.last_name}\\nIndustry: ${$json.industry}\\nGoogle Rating: ${$json.rating} stars (${$json.user_ratings_total} reviews)\\nCity: ${$json.city}, ${$json.state}\\nOwner Verification Context: ${$json.owner_verification_context}\\n\\nReturn JSON only.`) }}\n    }\n  ]\n}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          },
          "timeout": 60000
        }
      },
      "id": "claude-email",
      "name": "Generate Email via Claude",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2660, 200],
      "credentials": {
        "httpHeaderAuth": {
          "id": "anthropic_api_key",
          "name": "anthropic_api_key"
        }
      },
      "onError": "continueErrorOutput",
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "// Parse Claude's JSON response and merge with lead data.\n// On parse failure, mark lead status as 'Email Generation Failed'.\n\nconst items = $input.all();\nconst out = [];\n\nfor (const item of items) {\n  const response = item.json;\n  const lead = $('Route: Qualified vs Discarded').item.json;\n\n  let subject = '';\n  let body = '';\n  let status = 'Ready to Send';\n\n  try {\n    const content = response && response.content && response.content[0] && response.content[0].text;\n    if (!content) throw new Error('No content in Claude response');\n\n    // Strip code fences if present, then parse\n    const cleaned = content\n      .replace(/^```json\\s*/i, '')\n      .replace(/^```\\s*/, '')\n      .replace(/```\\s*$/, '')\n      .trim();\n\n    const parsed = JSON.parse(cleaned);\n    subject = parsed.subject || '';\n    body = parsed.body || '';\n\n    if (!subject || !body) {\n      status = 'Email Generation Failed';\n    }\n  } catch (err) {\n    status = 'Email Generation Failed';\n    subject = '';\n    body = '';\n  }\n\n  out.push({\n    json: {\n      ...lead,\n      email_subject: subject,\n      email_body: body,\n      lead_status: status\n    }\n  });\n}\n\nreturn out;\n"
      },
      "id": "parse-claude",
      "name": "Parse Claude Email JSON",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2880, 200]
    },
