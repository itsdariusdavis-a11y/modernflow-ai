      "id": "serp-enrich",
      "name": "Enrich via SerpAPI",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1780, 300],
      "credentials": {
        "httpQueryAuth": {
          "id": "serp_api_key",
