    {
      "parameters": {
        "jsCode": "// Build owner_verification_context from SerpAPI organic results.\n// If SerpAPI failed or returned no results, fall back to 'Search unavailable'.\n\nconst items = $input.all();\nconst out = [];\n\nfor (const item of items) {\n  const lead = item.json;\n  let context = 'Search unavailable';\n\n  try {\n    const organic = lead.organic_results || [];\n    if (Array.isArray(organic) && organic.length > 0) {\n      const top = organic.slice(0, 3).map((r, i) => {\n        const title = r.title || '';\n        const snippet = r.snippet || '';\n        return `(${i + 1}) ${title} — ${snippet}`;\n      }).join(' | ');\n      if (top.trim().length > 0) context = top;\n    }\n  } catch (err) {\n    context = 'Search unavailable';\n  }\n\n  // Pull normalized lead fields from earlier in the chain\n  const normalized = $('Parse Maps Result').item.json;\n  const leadFields = $('Normalize Lead Fields').item.json;\n\n  out.push({\n    json: {\n      ...leadFields,\n      ...normalized,\n      owner_verification_context: context\n    }\n  });\n}\n\nreturn out;\n"
      },
      "id": "build-context",
      "name": "Build Owner Verification Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2000, 300]
    },
    {
      "parameters": {
        "jsCode": "// STEP 4 — DEDUP + SCRUB FILTER\n// Returns each item with `__qualified` boolean and `__discard_reason` string.\n// Routing happens in the IF node downstream.\n\nconst items = $input.all();\nconst seenOrgs = new Set();\nconst targetIndustries = ['HVAC', 'Plumbing', 'Roofing', 'Electrical', 'Auto Repair'];\nconst freeEmailDomains = ['gmail.com', 'yahoo.com', 'hotmail.com', 'outlook.com'];\n\nconst out = [];\n\nfor (const item of items) {\n  const lead = { ...item.json };\n  let qualified = true;\n  let reason = '';\n\n  const email = (lead.email || '').toLowerCase().trim();\n  const firstName = (lead.first_name || '').trim();\n  const lastName = (lead.last_name || '').trim();\n  const org = (lead.organization_name || '').trim().toLowerCase();\n  const industry = (lead.industry || '').trim();\n  const bizStatus = (lead.business_status || '').trim();\n\n  if (!email) {\n    qualified = false;\n    reason = 'Missing email';\n  } else {\n    const domain = email.split('@')[1] || '';\n    if (freeEmailDomains.includes(domain)) {\n      qualified = false;\n      reason = `Free email domain (${domain})`;\n    }\n  }\n\n  if (qualified && bizStatus && bizStatus !== 'Not Found' && bizStatus !== 'OPERATIONAL') {\n    qualified = false;\n    reason = `Business status: ${bizStatus}`;\n  }\n\n  if (qualified && (!firstName || !lastName)) {\n    qualified = false;\n    reason = 'Missing first or last name';\n  }\n\n  if (qualified) {\n    const matchIndustry = targetIndustries.some(t =>\n      industry.toLowerCase().includes(t.toLowerCase())\n    );\n    if (!matchIndustry) {\n      qualified = false;\n      reason = `Industry mismatch: ${industry || 'unknown'}`;\n    }\n  }\n\n  if (qualified && org) {\n    if (seenOrgs.has(org)) {\n      qualified = false;\n      reason = 'Duplicate organization';\n    } else {\n      seenOrgs.add(org);\n    }\n  }\n\n  lead.__qualified = qualified;\n  lead.__discard_reason = reason;\n  out.push({ json: lead });\n}\n\nreturn out;\n"
      },
      "id": "dedup-scrub",
      "name": "Dedup + Scrub Filter",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2220, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
