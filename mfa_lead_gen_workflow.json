      "parameters": {
        "jsCode": "// Final summary node — aggregates run stats and outputs a single summary item.\n\nconst apolloLeads = $('Split Apollo People').all().length;\nconst qualified = $('Route: Qualified vs Discarded').all().length;\nconst discarded = apolloLeads - qualified;\nconst drafts = $('Create Gmail Draft').all().length;\nconst gmailErrors = $('Log Gmail Draft Failure').all().length;\nconst emailGenFailed = $('Parse Claude Email JSON').all().filter(i => i.json.lead_status === 'Email Generation Failed').length;\nconst totalErrors = gmailErrors + emailGenFailed;\n\nconst summary = {\n  run_date: $('Set Workflow Variables').item.json.RUN_DATE,\n  total_leads_pulled_from_apollo: apolloLeads,\n  total_leads_qualified: qualified,\n  total_leads_discarded: discarded,\n  total_gmail_drafts_created: drafts,\n  total_errors_encountered: totalErrors,\n  errors_breakdown: {\n    claude_email_generation_failed: emailGenFailed,\n    gmail_draft_failed: gmailErrors\n  }\n};\n\nconsole.log('=== MFA Lead Gen Run Summary ===');\nconsole.log(JSON.stringify(summary, null, 2));\n\nreturn [{ json: summary }];\n"
