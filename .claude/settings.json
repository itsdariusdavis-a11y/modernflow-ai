{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm check)",
      "Bash(pnpm test)",
      "Bash(pnpm test:*)",
      "Bash(pnpm format)",
      "Bash(pnpm build)",
      "Bash(pnpm install)",
      "Bash(pnpm dev)",
      "Bash(pnpm db:push)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git fetch:*)",
      "Bash(git stash:*)",
      "Read",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(git push origin main:*)",
      "Bash(git push -u origin main:*)",
      "Read(./server/.env)",
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  }
}
